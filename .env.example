# Frontend environment variables
# Copy this file to .env and fill in the values.

# Supabase public browser config. Safe to expose in frontend builds.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# API base URL.
# Local dev: leave empty so requests use same-origin /api and Vite proxy.
# Production: set this to your deployed backend URL, for example:
# VITE_API_URL=https://your-api.onrender.com
VITE_API_URL=
