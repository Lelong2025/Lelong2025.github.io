# Frontend (Next.js static export / GitHub Pages)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# Backend (Render only — never expose these with NEXT_PUBLIC_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key
OPENAI_API_KEY=your_openai_api_key
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
SEPAY_BANK=your_bank_code
SEPAY_ACCOUNT_NUMBER=your_account_number
SEPAY_ACCOUNT_NAME=your_account_name

# Comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,https://your-name.github.io

# Optional backend tuning
PORT=10000
AI_RATE_LIMIT_MAX=30
AI_RATE_LIMIT_WINDOW_MS=60000
