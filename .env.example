# Supabase credentials — TEMPLATE
# Copy file này thành `.env` và điền keys thật từ Supabase Dashboard.
# File `.env` đã có trong `.gitignore` — KHÔNG BAO GIỜ commit nó.
#
# Lấy keys tại: https://supabase.com/dashboard/project/<project-ref>/settings/api

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=service_role_secret_key_here
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxx
SUPABASE_JWKS_URL=https://YOUR-PROJECT-REF.supabase.co/auth/v1/.well-known/jwks.json
